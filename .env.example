# --- 环境 ---
APP_ENV=dev
APP_NAME=carwork
APP_DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-long-random-string
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# --- PostgreSQL ---
POSTGRES_USER=carwork
POSTGRES_PASSWORD=carwork
POSTGRES_DB=carwork
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://carwork:carwork@postgres:5432/carwork

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- MinIO / 对象存储 ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=carwork
MINIO_SECURE=false

# --- AI: LLM 供应商（OpenAI 兼容协议）---
# Docker 部署时如需本机私有覆盖，请新建 .env.docker.local，只放 API Key 等容器可用配置；
# 不要直接复用 .env.local（通常含 localhost 数据库地址）。
# 默认主供应商
LLM_DEFAULT_PROVIDER=deepseek
# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_MODEL=deepseek-v4-pro
# 通义千问 (DashScope OpenAI 兼容)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_CHAT_MODEL=qwen-plus
DASHSCOPE_VL_MODEL=qwen-vl-max
# 智谱 GLM
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_CHAT_MODEL=glm-4-flash

# 通用 MaaS（OpenAI 兼容聚合网关，可同时承载文本与视觉模型，如 minimax / qwen-vl）
MAAS_API_KEY=
MAAS_BASE_URL=
MAAS_CHAT_MODEL=minimax2.7
MAAS_VL_MODEL=qwen3-vl-plus

# --- AI: OCR ---
OCR_DEFAULT_PROVIDER=aliyun
ALIYUN_OCR_ACCESS_KEY=
ALIYUN_OCR_SECRET_KEY=

# --- JWT / 认证 ---
ACCESS_TOKEN_EXPIRE_MINUTES=10080
